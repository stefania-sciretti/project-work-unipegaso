# ─── Java / Kotlin ───────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.nar
*.ear
hs_err_pid*
replay_pid*

# ─── Maven build output ───────────────────────────────────────────────────────
# The entire target/ directory is generated by "mvn package" — never commit it.
backend/target/

# ─── Angular build output ────────────────────────────────────────────────────
# The frontend build is copied here by "ng build". It is regenerated on every
# build, so it must NOT be committed alongside the TypeScript sources.
backend/src/main/resources/static/

# ─── Node / Angular dev dependencies ─────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.angular/

# ─── IDE & OS ────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
*.log.*

# ─── Kotlin ──────────────────────────────────────────────────────────────────
.kotlin/